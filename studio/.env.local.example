# Example values for studio/.env.local
# For mode switching use:
# - studio/.env.local.template (local mode)
# - studio/.env.deploy.template (deploy mode)
#
# Localhost or live site for preview mode
SANITY_STUDIO_PREVIEW_URL=http://localhost:3000
SANITY_STUDIO_API_VERSION=2026-03-23
SANITY_STUDIO_PROJECT_ID=replace-me-project-id
SANITY_STUDIO_DATASET=production
SANITY_STUDIO_HOSTNAME=replace-me-studio-hostname
SANITY_AUTH_TOKEN=replace-me-sanity-auth-token
SANITY_STUDIO_APP_ID=replace-me-studio-app-id