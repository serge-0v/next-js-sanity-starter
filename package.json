{
  "name": "schema-ui-next-js-sanity-starter",
  "version": "2.0.0",
  "description": "Schema UI: Next.js + Sanity Starter Template",
  "private": true,
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:studio": "pnpm --filter studio dev",
    "env:local": "node scripts/switch-env.mjs local",
    "env:deploy": "node scripts/switch-env.mjs deploy",
    "env:show": "node -e \"const fs=require('node:fs');const p=['frontend/.env.local','studio/.env.local'];for (const f of p){const s=fs.existsSync(f)?'present':'missing';console.log(f+': '+s);}\"",
    "typegen": "pnpm --filter studio typegen",
    "typecheck": "pnpm --filter frontend typecheck",
    "export": "pnpm --filter studio exec sanity dataset export production sample-data.tar.gz"
  },
  "homepage": "https://www.schemaui.com/"
}
